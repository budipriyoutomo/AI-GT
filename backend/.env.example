# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aigt_db

# Auth provider — "jwt" atau "supabase" (ganti di sini, 0 perubahan kode)
AUTH_PROVIDER=jwt

# JWT — dipakai jika AUTH_PROVIDER=jwt
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Supabase — dipakai jika AUTH_PROVIDER=supabase
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard

# AI — copy
AI_COPY_PROVIDER=anthropic
AI_COPY_MODEL=claude-haiku-4-5

# AI — image
AI_IMAGE_PROVIDER=replicate
AI_IMAGE_MODEL=stability-ai/sdxl

# API keys
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...
DEEPSEEK_API_KEY=sk-...

